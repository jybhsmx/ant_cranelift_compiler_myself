struct A<T> { 
    val: T
}

func f<T>(val: T) -> T {
    val
}

func main() -> i32 {
    let o = new A {
        val = 1i64
    };

    extern "C" func printf(s: str, ...) -> i32;

    printf("generic struct.val: %d\n", o.val)
    printf("generic func ret val: %d\n", f(o.val))
    printf("generic func ret val * 2: %d\n", f(o.val) + f(o.val))
}